# LLM Provider (gigachat / openai)
LLM_PROVIDER=gigachat
OPENAI_API_KEY=
GIGACHAT_API_KEY=
GIGACHAT_CREDENTIALS=

# Audio transcription (whisper-api / mock)
AUDIO_PROVIDER=whisper

# Storage paths
UPLOAD_DIR=uploads
RESULTS_DIR=results

# Server
HOST=0.0.0.0
PORT=8000

# Mode: set MOCK_MODE=1 to run without real API keys
MOCK_MODE=0
